# ProxyRank — environment variables
# Copy this file to .env and fill in your values.

# ── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (intent embedding) ───────────────────────────────────────────────
OPENAI_API_KEY=

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Grok (community reply drafting) ────────────────────────────────────────
GROK_API_KEY=

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN_COMMUNITY_MONITOR=   # Bot A — posts hits to the group
TELEGRAM_CHAT_ID=                        # Group chat ID (negative number)
# Claude Channels bot token is configured separately via /telegram:configure

# ── Discord (optional — add later) ──────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ── X / Twitter (optional) ──────────────────────────────────────────────────
X_BEARER_TOKEN=       # read-only search
X_API_KEY=            # OAuth1.0a — only needed for auto-posting replies
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Data directory (optional) ───────────────────────────────────────────────
# DATA_DIR=/path/to/data   # defaults to script directory
