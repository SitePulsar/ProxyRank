# ProxyRank Community Monitor — environment variables
# Copy this file to .env and fill in your values.

# ── Required ───────────────────────────────────────────────────────────────
GROK_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional: X / Twitter ──────────────────────────────────────────────────
# X_BEARER_TOKEN enables X search (read-only, free dev account)
X_BEARER_TOKEN=

# OAuth1.0a credentials required for POSTING replies to X.
# Get these from developer.twitter.com → Your App → Keys and Tokens.
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Optional: data directory ───────────────────────────────────────────────
# Defaults to the directory containing community_monitor.py
# DATA_DIR=/path/to/data

# ── TODO: Discord (add later) ──────────────────────────────────────────────
# DISCORD_WEBHOOK_URL=
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=
